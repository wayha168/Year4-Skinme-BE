{
  "info": {
    "_postman_id": "skinme-api-qa-2026",
    "name": "SkinMe API — QA Collection",
    "description": "CRUD + auth flows for SkinMe backend. Run Login first. Uses environment variables: baseUrl, apiPrefix, jwtToken, categoryId.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{jwtToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "01 Login — Admin (sets jwtToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has message', () => pm.expect(json).to.have.property('message'));",
                  "pm.test('Has data', () => pm.expect(json).to.have.property('data'));",
                  "const cookies = pm.response.headers.get('Set-Cookie');",
                  "if (cookies && cookies.includes('token=')) {",
                  "  const m = cookies.match(/token=([^;]+)/);",
                  "  if (m) pm.environment.set('jwtToken', m[1]);",
                  "}",
                  "if (json.data && json.data.token) pm.environment.set('jwtToken', json.data.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/auth/login"
          }
        },
        {
          "name": "02 Login — Wrong password (sad)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 or 400', () => pm.expect([400,401]).to.include(pm.response.code));",
                  "pm.test('JSON has message', () => pm.expect(pm.response.json()).to.have.property('message'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"wrong-password-qa\"\n}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Products (read public)",
      "item": [
        {
          "name": "03 GET All Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has message', () => pm.expect(json).to.have.property('message'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}{{apiPrefix}}/products/all"
          }
        },
        {
          "name": "04 GET Product By Id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 404', () => pm.expect([200,404]).to.include(pm.response.code));",
                  "pm.test('Has message', () => pm.expect(pm.response.json()).to.have.property('message'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}{{apiPrefix}}/products/product/{{productId}}/product"
          }
        }
      ]
    },
    {
      "name": "CRUD — Categories (Admin)",
      "item": [
        {
          "name": "05 CREATE Category",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": ["pm.environment.set('categoryName', 'QA-Cat-' + Date.now());"],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Category created', () => {",
                  "  pm.expect(json.data).to.have.property('id');",
                  "  pm.environment.set('categoryId', json.data.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{categoryName}}\"\n}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/categories/add-category"
          }
        },
        {
          "name": "06 READ Category By Id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Data has id', () => pm.expect(pm.response.json().data).to.have.property('id'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}{{apiPrefix}}/categories/category/{{categoryId}}/category"
          }
        },
        {
          "name": "07 UPDATE Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Update message', () => pm.expect(pm.response.json().message).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{categoryName}}-updated\"\n}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/categories/category/{{categoryId}}/update"
          }
        },
        {
          "name": "08 DELETE Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has message', () => pm.expect(pm.response.json()).to.have.property('message'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}{{apiPrefix}}/categories/category/{{categoryId}}/delete"
          }
        },
        {
          "name": "09 READ Category After Delete (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));",
                  "pm.test('Has message', () => pm.expect(pm.response.json()).to.have.property('message'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}{{apiPrefix}}/categories/category/{{categoryId}}/category"
          }
        }
      ]
    },
    {
      "name": "Cart (Auth required)",
      "item": [
        {
          "name": "10 GET My Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has data', () => pm.expect(pm.response.json()).to.have.property('data'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}{{apiPrefix}}/carts/my-cart"
          }
        },
        {
          "name": "11 Add Cart Item — No Auth (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('Unauthorized', () => pm.response.code === 401);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/cartItems/item/add?productId={{productId}}&quantity=1",
              "host": ["{{baseUrl}}{{apiPrefix}}"],
              "path": ["cartItems", "item", "add"],
              "query": [
                { "key": "productId", "value": "{{productId}}" },
                { "key": "quantity", "value": "1" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Promotions",
      "item": [
        {
          "name": "12 GET Active Promotions",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has message', () => pm.expect(pm.response.json()).to.have.property('message'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}{{apiPrefix}}/promotions/active"
          }
        }
      ]
    }
  ]
}
